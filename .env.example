# Copy to `.env` for local runs, or set as Cloud Run Job env vars on deploy.
# Each notification channel needs its own secret; only set the ones you enable
# in config.json (email, slack, or both).

# Email (Gmail) — requires a 16-char App Password, not your normal password:
#   Google Account > Security > 2-Step Verification > App passwords
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx

# Slack — an Incoming Webhook URL bound to the channel you want to post to:
#   https://api.slack.com/messaging/webhooks
# (real value looks like https://hooks.slack.com/services/<team>/<channel>/<token>)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE/WITH/YOUR_WEBHOOK
